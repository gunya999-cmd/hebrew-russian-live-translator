{
  "name": "hebrew-russian-live-translator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:worker": "wrangler dev --local",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.0",
    "vite": "7.1.3",
    "typescript": "5.9.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "wrangler": "4.31.0"
  },
  "devDependencies": {
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@cloudflare/workers-types": "4.20250823.0"
  }
}
